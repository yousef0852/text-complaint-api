# Copy this file to `.env` and fill in your secrets (never commit `.env`).

# Hugging Face — required to download MARBERT models
HF_TOKEN=

# OpenAI-compatible API — optional; enables POST /explain-classification explanations
# Get a key at https://platform.openai.com/api-keys (or use another compatible provider)
OPENAI_API_KEY=

LLM_ENABLED=true
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1
LLM_TIMEOUT_SECONDS=30
LLM_MAX_COMPLETION_TOKENS=512

# Classification thresholds (0.0–1.0)
SENTIMENT_THRESHOLD=0.7
TOPIC_THRESHOLD=0.7
INTENT_THRESHOLD=0.7

ENABLE_CONFIDENCE_GUARDING=true
MANUAL_REVIEW_ON_LOW_CONFIDENCE=true
ENABLE_PREDICTION_LOGGING=false
